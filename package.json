{
  "name": "atmosphere-rss",
  "version": "0.1.0",
  "description": "Import RSS feeds as standard.site publications and documents on the AT Protocol",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
